# Server
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:8081

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/piki_food?schema=public"

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-at-least-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Redis (BullMQ + Socket.IO)
REDIS_URL=redis://localhost:6379

# Email (for OTP delivery via email; leave blank to use Ethereal test account)
EMAIL_HOST=smtp.ethereal.email
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=noreply@piki.food

# Self-hosted SMTP server (runs in-process, no external dependency)
# When EMAIL_USER is empty, the app runs its own SMTP server on SELF_HOSTED_SMTP_PORT
SELF_HOSTED_SMTP_PORT=2525
SELF_HOSTED_DOMAIN=piki.food

# SMTP Relay (optional — for environments where direct MX delivery is blocked)
# Set these to relay all outbound emails through an authenticated SMTP server
# e.g., Gmail SMTP (smtp.gmail.com:587) with an app password
EMAIL_RELAY_HOST=
EMAIL_RELAY_PORT=587
EMAIL_RELAY_USER=
EMAIL_RELAY_PASS=

# Africa's Talking (for SMS OTP delivery)
AT_USERNAME=
AT_API_KEY=
AT_FROM=

# OTP (for dev, OTP is logged to console; for prod, use Twilio/AWS SNS)
OTP_PROVIDER=console

# File Storage (S3-compatible)
STORAGE_PROVIDER=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BUCKET=

# Stripe (stub for now)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# FCM Push Notifications
FCM_SERVER_KEY=



CONNESTRING=postgresql://neondb_owner:npg_pkTWY5Da3hVI@ep-flat-tooth-aqzrujfq.c-8.us-east-1.aws.neon.tech/neondb?sslmode=require