{
  "name": "piki-food-backend",
  "version": "1.0.0",
  "description": "Production backend for Piki Food delivery app",
  "main": "dist/index.js",
  "scripts": {
    "up": "nodemon index.ts",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc && tsc-alias",
    "clean": "rm -rf dist",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "piki",
    "food-delivery",
    "backend",
    "api"
  ],
  "author": "Piki Food",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1063.0",
    "@prisma/client": "^6.6.0",
    "@types/smtp-server": "^3.5.13",
    "africastalking": "^0.7.4",
    "axios": "^1.5.0",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.46.0",
    "compression": "^1.8.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.6.0",
    "jsonwebtoken": "^9.0.2",
    "module-alias": "^2.3.4",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.7",
    "nodemon": "^3.1.14",
    "smtp-server": "^3.18.4",
    "socket.io": "^4.8.1",
    "stripe": "^18.0.0",
    "uuid": "^11.1.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.5",
    "@types/nodemailer": "^6.4.17",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^9.25.0",
    "eslint-config-prettier": "^10.1.0",
    "eslint-plugin-import": "^2.31.0",
    "prettier": "^3.4.2",
    "prisma": "^6.6.0",
    "supertest": "^7.1.0",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^4.1.6"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
